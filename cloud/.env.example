# Server
    PORT=3001
    NODE_ENV=development
    
    # JWT
    JWT_SECRET=change-me-to-a-random-string
    JWT_EXPIRES_IN=24h
    
    # LLM Provider
    LLM_PROVIDER=deepseek
    DEEPSEEK_API_KEY=sk-your-key-here
    OPENAI_API_KEY=sk-your-key-here
    
    # Memory
    MEMORY_DIR=./memory
    