# ============================================
    # VARIAVEIS DE AMBIENTE - colabor-ai Cloud
    # ============================================
    # Copie este arquivo para .env e preencha os valores
    # cp .env.example .env
    
    # === Servidor ===
    PORT=3001
    
    # === PostgreSQL com pgvector ===
    # URL de conexao fornecida pelo Render
    DATABASE_URL=postgresql://user:password@host:5432/db_name
    
    # === Google OAuth2.0 ===
    # Credenciais do Google Cloud Console (https://console.cloud.google.com)
    GOOGLE_CLIENT_ID=seu_google_client_id
    GOOGLE_CLIENT_SECRET=seu_google_client_secret
    
    # === JWT ===
    # Chave secreta para assinar tokens JWT (use uma string longa e aleatoria)
    JWT_SECRET=seu_jwt_secret_aqui_minimo_32_caracteres
    
    # === OpenAI ===
    OPENAI_API_KEY=sua_openai_api_key
    