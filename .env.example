# ============================================
    # VARIAVEIS DE AMBIENTE - colabor-ai
    # ============================================
    # Copie este arquivo para .env e preencha os valores
    # cp .env.example .env
    
    # === API Keys ===
    
    # OpenAI API Key (obrigatorio se usar modelo OpenAI)
    OPENAI_API_KEY=
    
    # DeepSeek API Key (alternativa ao OpenAI)
    DEEPSEEK_API_KEY=
    
    # === Telegram ===
    
    # Token do bot Telegram (obrigatorio para modo Telegram)
    TELEGRAM_BOT_TOKEN=
    
    # === Navegador (Puppeteer) ===
    
    # Caminho para o executavel do Chrome (opcional - usa padrao do sistema se vazio)
    CHROME_PATH=
    
    # Modo headless do Puppeteer (true/false, default: true)
    PUPPETEER_HEADLESS=true
    
    
    # === Thinking Agent ===
    
    # Modelo do ThinkingAgent (modelo simples SEM reasoning, ex: deepseek-chat)
    # Default: deepseek-chat
    THINKING_MODEL=deepseek-chat
    
    # === Logging ===
    
    # Nivel de log: debug, info, warn, error (default: info)
    LOG_LEVEL=info
    