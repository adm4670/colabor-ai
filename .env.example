# ============================================
        # colabor-ai-core - Environment Variables
        # v3 (flash-optimized)
        # ============================================
        
        # --- LLM API Keys ---
        OPENAI_API_KEY=sk-your-openai-api-key
        DEEPSEEK_API_KEY=sk-your-deepseek-api-key
        
        # --- Model Selection (flash-optimized) ---
        # MODEL=deepseek-v4-flash          # Modelo default (barato)
        # PLANNER_MODEL=deepseek-v4-flash  # Planner (roteamento)
        # PLANNER_COMPLEX_MODEL=deepseek-v4-pro  # Planner (planos complexos)
        # EXECUTOR_MODEL=deepseek-v4-flash # Agentes executores
        # REFLECTOR_MODEL=deepseek-v4-flash # Agente de reflexao
        # SUMMARIZER_MODEL=deepseek-v4-flash # Sumarizacao
        
        # --- Context Budget (flash-optimized) ---
        # CONTEXT_MAX_TOKENS=4000           # Budget maximo (flash: 4000)
        
        # --- Feature Flags ---
        # LAZY_SKILLS=true                  # Skills sob demanda
        # LAZY_MEMORY=true                  # Memoria sob demanda
        # PREFIX_CACHING=true               # Cache de prefixo
        # FAST_PATH=true                    # Fast-path queries simples
        
        # --- Telegram ---
        TELEGRAM_TOKEN=your-telegram-bot-token
        
        # --- Python Execution ---
        PYTHON_TIMEOUT=30000
        
        # --- Rate Limiting ---
        MAX_MESSAGES_PER_SESSION=50
        
        # --- MongoDB (optional) ---
        MONGODB_URI=mongodb://localhost:27017/colabor-ai
        
        # --- Puppeteer / Browser Automation ---
        PUPPETEER_HEADLESS=true
    